{
  "annotations": { "list": [] },
  "description": "MindPal 系统全局可观测性 Dashboard — API 延迟 / 队列积压 / 错误率 / 评测 / 辩论",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API 请求速率 (QPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(mindpal_http_requests_total[5m])) by (status_class)",
          "legendFormat": "{{status_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "none" } }
        }
      }
    },
    {
      "title": "API P50/P95/P99 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(mindpal_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mindpal_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mindpal_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "错误率 (5xx / 总请求)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(mindpal_http_requests_total{status_class=\"5xx\"}[5m])) / sum(rate(mindpal_http_requests_total[5m])) * 100",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "授权拒绝率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(mindpal_authz_denied_total[5m]))",
          "legendFormat": "denied/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 2, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "审计写入失败率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(mindpal_audit_write_failed_total[5m]))",
          "legendFormat": "failed/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "进程运行时间",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "mindpal_process_uptime_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "队列积压",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "mindpal_workflow_queue_backlog",
          "legendFormat": "workflow {{status}}"
        },
        {
          "expr": "mindpal_audit_outbox_backlog",
          "legendFormat": "audit_outbox {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "DB 连接池",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "mindpal_db_pool_total", "legendFormat": "total" },
        { "expr": "mindpal_db_pool_idle", "legendFormat": "idle" },
        { "expr": "mindpal_db_pool_waiting", "legendFormat": "waiting" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      }
    },
    {
      "title": "Eval Suite 通过/失败",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mindpal_eval_run_total{action=\"passed\"}[5m]))", "legendFormat": "passed" },
        { "expr": "sum(rate(mindpal_eval_run_total{action=\"not_passed\"}[5m]))", "legendFormat": "not_passed" },
        { "expr": "sum(rate(mindpal_eval_run_total{action=\"failed\"}[5m]))", "legendFormat": "failed" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      }
    },
    {
      "title": "Eval 门禁阻断",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mindpal_eval_gate_blocked_total[5m])) by (reason)", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }
      }
    },
    {
      "title": "辩论机制",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mindpal_debate_sessions_total[5m])) by (result)", "legendFormat": "{{result}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(mindpal_debate_duration_ms_bucket[5m])) by (le))", "legendFormat": "P95 duration" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      }
    },
    {
      "title": "冲突解决",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mindpal_conflict_resolution_total[5m])) by (strategy)", "legendFormat": "{{strategy}}" },
        { "expr": "sum(rate(mindpal_conflict_manual_required_total[5m]))", "legendFormat": "manual_required" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }
      }
    },
    {
      "title": "Sync Push/Pull 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(mindpal_sync_push_duration_ms_bucket[5m])) by (le))", "legendFormat": "push P95" },
        { "expr": "histogram_quantile(0.95, sum(rate(mindpal_sync_pull_duration_ms_bucket[5m])) by (le))", "legendFormat": "pull P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      }
    },
    {
      "title": "SSO 登录 & SCIM 操作",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(mindpal_sso_login_total[5m])) by (result)", "legendFormat": "sso_{{result}}" },
        { "expr": "sum(rate(mindpal_scim_operation_total[5m])) by (result)", "legendFormat": "scim_{{result}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mindpal", "api", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "MindPal System Overview",
  "uid": "mindpal-overview-v1"
}

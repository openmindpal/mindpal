{
  "identity": {
    "name": "bridge.send",
    "version": "1.0.0"
  },
  "displayName": {
    "zh-CN": "Bridge 桥接消息发送",
    "en-US": "Bridge Message Send"
  },
  "description": {
    "zh-CN": "通过 Bridge 协议向 IM 平台（QQ、iMessage 等）发送消息，支持幂等性和追踪",
    "en-US": "Sends messages to IM platforms (QQ, iMessage, etc.) via Bridge protocol, supports idempotency and tracing"
  },
  "category": "communication",
  "priority": 7,
  "tags": ["bridge", "im", "qq", "imessage", "outbound"],
  "contract": {
    "scope": "write",
    "resourceType": "channel",
    "action": "send",
    "idempotencyRequired": false,
    "riskLevel": "low",
    "approvalRequired": false
  },
  "io": {
    "inputSchema": {
      "fields": {
        "baseUrl": { "type": "string", "required": true },
        "secret": { "type": "string", "required": true },
        "provider": { "type": "string", "required": true },
        "workspaceId": { "type": "string", "required": true },
        "requestId": { "type": "string", "required": true },
        "traceId": { "type": "string", "required": true },
        "to": { "type": "json", "required": true },
        "message": { "type": "json", "required": true },
        "idempotencyKey": { "type": "string", "required": true }
      }
    },
    "outputSchema": {
      "fields": {
        "ok": { "type": "boolean", "required": true }
      }
    }
  },
  "entry": "dist/index.js"
}

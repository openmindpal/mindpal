{
  "identity": {
    "name": "slack.send",
    "version": "1.0.0"
  },
  "displayName": {
    "zh-CN": "Slack 消息发送",
    "en-US": "Slack Message Send"
  },
  "description": {
    "zh-CN": "向指定的 Slack 频道或用户发送消息",
    "en-US": "Sends messages to specified Slack channel or user"
  },
  "category": "communication",
  "priority": 7,
  "tags": ["slack", "messaging", "notification", "outbound"],
  "contract": {
    "scope": "write",
    "resourceType": "channel",
    "action": "send",
    "idempotencyRequired": false,
    "riskLevel": "low",
    "approvalRequired": false
  },
  "io": {
    "inputSchema": {
      "fields": {
        "botToken": { "type": "string", "required": true },
        "channel": { "type": "string", "required": true },
        "text": { "type": "string", "required": true }
      }
    },
    "outputSchema": {
      "fields": {
        "ok": { "type": "boolean", "required": true }
      }
    }
  },
  "entry": "dist/index.js"
}

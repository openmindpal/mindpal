{
  "identity": { "name": "example.go", "version": "0.1.0" },
  "runtime": "go",
  "entry": "dist/skill",
  "description": "Go Skill开发模板 — 实现JSON-RPC over stdio协议",
  "io": {
    "inputSchema": {
      "type": "object",
      "properties": {
        "message": { "type": "string", "description": "输入消息" }
      },
      "required": ["message"]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "reply": { "type": "string", "description": "处理后的回复" }
      }
    }
  },
  "contract": {
    "scope": "read",
    "resourceType": "tool",
    "action": "execute",
    "riskLevel": "low",
    "approvalRequired": false
  }
}

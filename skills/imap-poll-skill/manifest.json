{
  "identity": {
    "name": "imap.poll",
    "version": "1.0.0"
  },
  "displayName": {
    "zh-CN": "IMAP 邮件轮询",
    "en-US": "IMAP Email Poll"
  },
  "description": {
    "zh-CN": "通过 IMAP 协议轮询邮箱，获取新邮件及其摘要、正文和附件信息",
    "en-US": "Polls mailbox via IMAP protocol to fetch new emails with summary, body, and attachments"
  },
  "category": "communication",
  "priority": 6,
  "tags": ["email", "imap", "poll", "inbound"],
  "dependencies": ["secrets", "scheduler"],
  "contract": {
    "scope": "read",
    "resourceType": "channel",
    "action": "poll",
    "idempotencyRequired": false,
    "riskLevel": "low",
    "approvalRequired": false
  },
  "io": {
    "inputSchema": {
      "fields": {
        "mailbox": { "type": "string", "required": true },
        "uidNext": { "type": "number", "required": true }
      }
    },
    "outputSchema": {
      "fields": {
        "uid": { "type": "number", "required": true },
        "internalDate": { "type": "string", "required": true },
        "summary": { "type": "json", "required": true },
        "body": { "type": "json", "required": true },
        "attachments": { "type": "json", "required": true },
        "watermarkAfter": { "type": "json", "required": true }
      }
    }
  },
  "semanticMeta": {
    "operationType": "query",
    "precisionLevel": "best_effort",
    "sideEffects": [],
    "semanticEquivalents": [],
    "notEquivalentTo": []
  },
  "engines": { "node": ">=18.0.0" },
  "entry": "dist/index.js"
}

{
  "identity": {
    "name": "exchange.poll",
    "version": "1.0.0"
  },
  "displayName": {
    "zh-CN": "Exchange 邮件轮询",
    "en-US": "Exchange Email Poll"
  },
  "description": {
    "zh-CN": "通过 Microsoft Graph API 轮询 Exchange 邮箱，获取新邮件列表和增量同步链接",
    "en-US": "Polls Exchange mailbox via Microsoft Graph API to fetch new emails and delta sync links"
  },
  "category": "communication",
  "priority": 6,
  "tags": ["email", "exchange", "microsoft", "poll", "inbound"],
  "dependencies": ["secrets", "scheduler"],
  "contract": {
    "scope": "read",
    "resourceType": "channel",
    "action": "poll",
    "idempotencyRequired": false,
    "riskLevel": "low",
    "approvalRequired": false
  },
  "io": {
    "inputSchema": {
      "fields": {
        "accessToken": { "type": "string", "required": true },
        "cursorUrl": { "type": "string", "required": true },
        "mailbox": { "type": "string", "required": true },
        "maxMessages": { "type": "number" },
        "timeoutMs": { "type": "number" }
      }
    },
    "outputSchema": {
      "fields": {
        "messages": { "type": "json", "required": true },
        "scannedCount": { "type": "number", "required": true },
        "nextLink": { "type": "string" },
        "deltaLink": { "type": "string" }
      }
    }
  },
  "engines": { "node": ">=18.0.0" },
  "entry": "dist/index.js"
}

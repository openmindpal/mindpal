{
  "name": "@mindpal/device-agent-sdk",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "description": "灵智MindPal端侧代理SDK内核 — 可嵌入的设备智能体运行时",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "default": "./dist/kernel/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "default": "./dist/transport/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@mindpal/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}

# ===========================================
# 灵智智能体系统 - 环境变量配置
# ===========================================
# 注意：端口值已与 .env 实际运行配置对齐，
# 修改端口后请同步更新 docker-compose.yml 及相关服务配置。

# ── 基础设施 ─────────────────────────────────

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_DB=mindpal
POSTGRES_USER=mindpal
POSTGRES_PASSWORD=openslin
POSTGRES_PORT=5432

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=7500

# MinIO 配置
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123456
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── API 服务 ──────────────────────────────────

API_PORT=4001
API_CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
API_INTERNAL_URL=http://localhost:3001
# API 监听地址（容器化部署用 0.0.0.0）
# API_HOST=0.0.0.0
PLATFORM_LOCALE=zh-CN
# 媒体文件根目录
# MEDIA_FS_ROOT_DIR=var/media
# Fastify 插件加载超时（ms）
# FASTIFY_PLUGIN_TIMEOUT_MS=120000

# ── 前端 ──────────────────────────────────────

# Web 前端访问 API 的 base（建议显式包含版本前缀 /v1）
# 示例：http://localhost:3001/v1
NEXT_PUBLIC_API_BASE=http://localhost:3001/v1
# 前端开发环境默认 token（仅限 dev 模式）
# NEXT_PUBLIC_DEV_DEFAULT_TOKEN=admin@space_dev

# ── Worker ────────────────────────────────────

# Worker BullMQ 并发度（默认 5）
# WORKER_CONCURRENCY=5
# Worker 优雅停机超时（ms，最小 10000，默认 30000）
# WORKER_SHUTDOWN_TIMEOUT_MS=30000
# 单个 Job 最大执行时长（ms，默认 300000 = 5分钟，0 = 不限制）
# WORKER_JOB_TIMEOUT_MS=300000
# Worker 健康检查端口
# WORKER_HEALTH_PORT=3002
# Worker 指标采集间隔（ms）
# WORKER_METRICS_INTERVAL_MS=60000
# Worker 队列积压告警阈值
# WORKER_BACKLOG_THRESHOLD=100
# Worker 与 API 通信地址
# WORKER_API_BASE=http://localhost:3001

# ── 认证 ──────────────────────────────────────

# 认证模式：dev / hmac / saml / oidc
AUTHN_MODE=dev
# HMAC 签名密钥（生产必填）
# AUTHN_HMAC_SECRET=
# API Master Key（生产必须修改）
# API_MASTER_KEY=

# ── 安全 ──────────────────────────────────────

# DLP 模式：audit_only / deny
# DLP_MODE=audit_only
# Prompt 注入检测模式（audit_only / deny）
# PROMPT_INJECTION_MODE=audit_only
# 内部 API 通信密钥
# INTERNAL_API_SECRET=

# ── Agent Loop ────────────────────────────────

# 全局最大并发 Agent Loop 数
# MAX_CONCURRENT_AGENT_LOOPS=50
# 目标分解开关（0 = 禁用）
# AGENT_LOOP_GOAL_DECOMPOSE=1
# 独立 Verifier Agent 开关（0 = 禁用）
# AGENT_LOOP_VERIFIER=1
# LLM 辅助世界状态提取开关
# AGENT_LOOP_LLM_EXTRACT=0
# 自动反思开关
# AGENT_LOOP_AUTO_REFLEXION=1
# Agent 准备缓存开关
# AGENT_PREPARE_CACHE_ENABLED=1
# 轻迭代模式开关
# AGENT_LIGHT_ITERATION=1

# ── 调度器 ────────────────────────────────────

# 饥饿检测阈值（ms）
# SCHEDULER_STARVATION_THRESHOLD_MS=120000
# 僵尸任务检测阈值（ms）
# TASK_QUEUE_ZOMBIE_THRESHOLD_MS=120000

# ── 意图锚定 ──────────────────────────────────

# 锚定规则配置文件路径
# INTENT_ANCHOR_RULES_PATH=
# LLM 辅助边界检查开关
# INTENT_ANCHOR_LLM_CHECK=0

# ── 目标分解 ──────────────────────────────────

# 分解模型超时（ms）
# GOAL_DECOMPOSE_MODEL_TIMEOUT_MS=60000

# ── 知识库 RAG ────────────────────────────────

# Embedding 模型配置
# KNOWLEDGE_EMBEDDING_ENDPOINT=
# KNOWLEDGE_EMBEDDING_MODEL=
# KNOWLEDGE_EMBEDDING_API_KEY=
# KNOWLEDGE_EMBEDDING_DIMENSIONS=1536
# KNOWLEDGE_EMBEDDING_BATCH_SIZE=32
# KNOWLEDGE_EMBEDDING_TIMEOUT_MS=30000

# 向量存储配置
# KNOWLEDGE_VECTOR_STORE_MODE=memory
# KNOWLEDGE_VECTOR_STORE_ENDPOINT=
# VECTOR_STORE_PROVIDER=

# 分块策略
# KNOWLEDGE_CHUNK_STRATEGY=recursive
# KNOWLEDGE_CHUNK_MAX_LEN=800
# KNOWLEDGE_CHUNK_OVERLAP=200

# ── 记忆系统 ──────────────────────────────────

# 记忆加密开关
# MEMORY_ENCRYPTION_ENABLED=false
# 记忆 Embedding 配置
# MEMORY_EMBEDDING_ENDPOINT=
# MEMORY_EMBEDDING_MODEL=
# MEMORY_EMBEDDING_API_KEY=

# ── Skill 运行时 ──────────────────────────────

# Skill 运行时后端：process / container / auto
# SKILL_RUNTIME_BACKEND=process
# Skill 远程运行时端点
# SKILL_RUNTIME_REMOTE_ENDPOINT=
# Skill 包根目录
# SKILL_PACKAGE_ROOTS=

# ── Runner（Skill 沙箱） ────────────────────────

# Runner Bearer Token
# RUNNER_BEARER_TOKEN=
# Runner 签名要求（生产默认 true）
# RUNNER_REQUIRE_SIGNATURE=false

# ── Device Agent ──────────────────────────────

# 设备 Agent 密钥
# DEVICE_AGENT_SECRET_KEY=
# 浏览器 CDP URL
# DEVICE_AGENT_BROWSER_CDP_URL=

# ── 语音（TTS/STT） ──────────────────────────

# --- Skill 层 STT（三级降级：讯飞 → Whisper → 多模态 LLM）---
# 讯飞语音听写（第一优先级，WebSocket 实时流式）
# 申请入口: https://console.xfyun.cn → 语音听写
# SKILL_IFLYTEK_APP_ID=
# SKILL_IFLYTEK_API_KEY=
# SKILL_IFLYTEK_API_SECRET=
# SKILL_IFLYTEK_TIMEOUT_MS=30000
# Whisper 兼容 API（第二优先级）
# SKILL_STT_ENDPOINT=https://api.openai.com/v1/audio/transcriptions
# SKILL_STT_API_KEY=
# SKILL_STT_MODEL=whisper-1
# SKILL_STT_TIMEOUT_MS=120000
# 多模态 LLM 降级（第三优先级）
# SKILL_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# SKILL_LLM_API_KEY=
# SKILL_LLM_MODEL=gpt-4o-audio-preview

# --- Skill 层 TTS（OpenAI 兼容）---
# SKILL_TTS_ENDPOINT=https://api.openai.com/v1/audio/speech
# SKILL_TTS_API_KEY=
# SKILL_TTS_MODEL=tts-1
# SKILL_TTS_TIMEOUT_MS=60000

# ── 审批引擎 ──────────────────────────────────

# 审批 HMAC 签名密钥（生产必须修改）
APPROVAL_SIGNING_KEY=your-approval-hmac-signing-key-change-me
# 审批过期时间（分钟）
# APPROVAL_EXPIRATION_MINUTES=1440
# 自动拒绝开关
# APPROVAL_AUTO_REJECT=false

# ── SSE 配置 ──────────────────────────────────

# 全局最大 SSE 连接数
# MAX_GLOBAL_SSE_CONNECTIONS=10000
# 单租户最大 SSE 连接数
# MAX_TENANT_SSE_CONNECTIONS=1000

# ── 种子数据（首次初始化） ──────────────────────

# SEED_TENANT_ID=tenant_dev
# SEED_SPACE_ID=space_dev
# SEED_ADMIN_SUBJECT_ID=admin
# SEED_WEB_SUBJECT_ID=web_user
# SEED_DEFAULT_MODEL_REF=

# ── 可观测性 ──────────────────────────────────

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_VERSION=0.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=dev
OTEL_DIAG=false

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
